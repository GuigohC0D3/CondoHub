# App
NODE_ENV=development
PORT=3333
APP_URL=http://localhost:3333
CORS_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgresql://condohub:condohub@localhost:5432/condohub?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth (gere segredos fortes: openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=5

# Storage S3 (opcional em dev; ex. AWS S3, Cloudflare R2, MinIO)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=false

# Billing (assinatura B2B da plataforma)
BILLING_WEBHOOK_SECRET=

# Gateway de cobrança do morador (PIX/Boleto).
# Sem ASAAS_API_KEY → usa o gateway stub (dev). Para validar no sandbox:
#   PAYMENT_PROVIDER=asaas e ASAAS_API_KEY=<chave de sandbox>  → npm run asaas:smoke
PAYMENT_PROVIDER=stub
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Segredo do webhook do Asaas (header asaas-access-token). Obrigatório em produção.
PAYMENTS_WEBHOOK_SECRET=

# Filas
QUEUE_ENABLED=true

# Observabilidade (Sentry) — sem DSN, roda só com logs estruturados
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# E-mail (Resend) — sem chave, roda em modo stub (só loga)
RESEND_API_KEY=
EMAIL_FROM=CondoHub <onboarding@resend.dev>
WEB_URL=http://localhost:5173
