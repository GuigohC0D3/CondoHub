// CondoHub — Multi-tenant SaaS para condomínios
// Estratégia multi-tenant: shared database + shared schema, isolamento por condominiumId.
// Toda query de domínio DEVE filtrar por condominiumId (enforced no middleware/Prisma extension).

generator client {
  provider      = "prisma-client-js"
  // native = ambiente local; debian-openssl-3.0.x = container (node:22-slim).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// PLATAFORMA (nível SaaS — sem tenant)
// ============================================================

enum PlanTier {
  FREE
  BASICO
  PROFISSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE   // inadimplente (grace period)
  CANCELED
  BLOCKED    // bloqueado por inadimplência
}

// Condomínio = o tenant. Raiz de todo isolamento de dados.
model Condominium {
  id           String   @id @default(uuid())
  name         String
  cnpj         String?  @unique
  slug         String   @unique // subdomínio: acme.condohub.com.br
  addressLine  String?
  city         String?
  state        String?  @db.Char(2)
  zipCode      String?
  logoUrl      String?
  timezone     String   @default("America/Sao_Paulo")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscription   Subscription?
  users          User[]
  blocks         Block[]
  apartments     Apartment[]
  residents      Resident[]
  notices        Notice[]
  commonAreas    CommonArea[]
  reservations   Reservation[]
  expenses       Expense[]
  revenues       Revenue[]
  tickets        Ticket[]
  visitors       Visitor[]
  packages       Package[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  invitations    Invitation[]
  charges        Charge[]
  chargeBatches  ChargeBatch[]
  assemblies     Assembly[]
  suggestions    Suggestion[]

  @@index([slug])
  @@index([isActive])
}

model Subscription {
  id              String             @id @default(uuid())
  condominiumId   String             @unique
  condominium     Condominium        @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  plan            PlanTier           @default(FREE)
  status          SubscriptionStatus @default(TRIALING)
  maxUnits        Int                @default(30) // limite de unidades por plano
  pricePerMonth   Decimal            @db.Decimal(10, 2)
  trialEndsAt     DateTime?
  currentPeriodEnd DateTime?
  gatewayCustomerId String?          // id do cliente no gateway (Stripe/Asaas/Pagar.me)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  payments        Payment[]

  @@index([status])
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  BOLETO
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// Cobrança da PLATAFORMA ao condomínio (B2B). Não confundir com boletos de morador.
model Payment {
  id             String        @id @default(uuid())
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  gatewayChargeId String?      @unique
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime      @default(now())

  @@index([subscriptionId, status])
  @@index([dueDate])
}

// ============================================================
// IDENTIDADE & ACESSO
// ============================================================

enum UserRole {
  SUPER_ADMIN  // administrador da plataforma (sem condominiumId)
  SINDICO
  MORADOR
  PORTEIRO
}

model User {
  id            String   @id @default(uuid())
  // SUPER_ADMIN tem condominiumId null; demais papéis sempre pertencem a um tenant.
  condominiumId String?
  condominium   Condominium? @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  name          String
  email         String
  passwordHash  String
  role          UserRole
  phone         String?
  avatarUrl     String?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  resident       Resident?
  refreshTokens  RefreshToken[]
  createdNotices Notice[]        @relation("NoticeAuthor")
  assignedTickets Ticket[]       @relation("TicketAssignee")
  ticketComments TicketComment[]
  auditLogs      AuditLog[]
  consents       ConsentRecord[]

  // Email único POR tenant (mesmo email pode existir em condomínios diferentes).
  @@unique([condominiumId, email])
  @@index([condominiumId, role])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // armazenar hash, nunca o token cru
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================
// ESTRUTURA FÍSICA & MORADORES
// ============================================================

model Block {
  id            String      @id @default(uuid())
  condominiumId String
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  name          String      // "Bloco A", "Torre 1"
  createdAt     DateTime    @default(now())

  apartments    Apartment[]

  @@unique([condominiumId, name])
  @@index([condominiumId])
}

model Apartment {
  id            String      @id @default(uuid())
  condominiumId String
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  blockId       String?
  block         Block?      @relation(fields: [blockId], references: [id], onDelete: SetNull)
  number        String      // "101", "1502"
  floor         Int?
  idealFraction Decimal?    @db.Decimal(9, 6) // fração ideal (peso de voto em assembleia)
  createdAt     DateTime    @default(now())

  residents     Resident[]
  packages      Package[]
  charges       Charge[]
  assemblyVotes       AssemblyVote[]
  assemblyAttendances AssemblyAttendance[]

  @@unique([condominiumId, blockId, number])
  @@index([condominiumId])
}

enum OccupancyType {
  OWNER       // proprietário
  TENANT      // inquilino
}

enum ResidentStatus {
  PENDING     // aguardando aprovação do síndico
  APPROVED
  REJECTED
  INACTIVE
}

model Resident {
  id            String        @id @default(uuid())
  condominiumId String
  condominium   Condominium   @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  userId        String?       @unique // vínculo opcional com conta de login
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  apartmentId   String
  apartment     Apartment     @relation(fields: [apartmentId], references: [id], onDelete: Restrict)

  fullName      String
  cpf           String
  phone         String?
  email         String?
  photoUrl      String?
  occupancy     OccupancyType @default(OWNER)
  status        ResidentStatus @default(PENDING)
  movedInAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  vehicles      Vehicle[]
  documents     ResidentDocument[]
  reservations  Reservation[]
  tickets       Ticket[]
  visitors      Visitor[]
  packages      Package[]
  history       ResidentHistory[]
  invitation    Invitation?
  charges       Charge[]
  assemblyVotes       AssemblyVote[]
  assemblyAttendances AssemblyAttendance[]
  suggestions         Suggestion[]
  suggestionVotes     SuggestionVote[]

  @@unique([condominiumId, cpf])
  @@index([condominiumId, status])
  @@index([apartmentId])
}

model Vehicle {
  id          String   @id @default(uuid())
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  plate       String
  model       String?
  color       String?
  createdAt   DateTime @default(now())

  @@index([residentId])
  @@index([plate])
}

model ResidentDocument {
  id          String   @id @default(uuid())
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  fileUrl     String   // S3 key
  fileName    String
  mimeType    String
  uploadedAt  DateTime @default(now())

  @@index([residentId])
}

// Histórico de alterações do cadastro do morador (auditoria de campo).
model ResidentHistory {
  id          String   @id @default(uuid())
  residentId  String
  resident    Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  changedBy   String   // userId
  field       String
  oldValue    String?
  newValue    String?
  changedAt   DateTime @default(now())

  @@index([residentId])
}

// ============================================================
// COMUNICAÇÃO
// ============================================================

model Notice {
  id            String      @id @default(uuid())
  condominiumId String
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation("NoticeAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  title         String
  body          String      @db.Text
  isPinned      Boolean     @default(false)
  publishedAt   DateTime    @default(now())
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())

  attachments   NoticeAttachment[]
  reads         NoticeRead[]

  @@index([condominiumId, isPinned, publishedAt])
}

model NoticeAttachment {
  id        String @id @default(uuid())
  noticeId  String
  notice    Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  fileUrl   String
  fileName  String
  mimeType  String

  @@index([noticeId])
}

// Confirmação de leitura por usuário (marcar como lido).
model NoticeRead {
  id       String   @id @default(uuid())
  noticeId String
  notice   Notice   @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  userId   String
  readAt   DateTime @default(now())

  @@unique([noticeId, userId])
  @@index([userId])
}

// ============================================================
// RESERVAS DE ÁREAS COMUNS
// ============================================================

enum ApprovalMode {
  AUTOMATIC
  MANUAL
}

model CommonArea {
  id            String       @id @default(uuid())
  condominiumId String
  condominium   Condominium  @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  name          String       // Salão de festas, Churrasqueira, Quadra, Piscina
  description   String?
  capacity      Int?
  openTime      String       @default("08:00") // janela diária permitida
  closeTime     String       @default("22:00")
  approvalMode  ApprovalMode @default(MANUAL)
  maxPerMonthPerResident Int @default(2)
  feeAmount     Decimal?     @db.Decimal(10, 2)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())

  reservations  Reservation[]

  @@index([condominiumId, isActive])
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model Reservation {
  id            String            @id @default(uuid())
  condominiumId String
  condominium   Condominium       @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  commonAreaId  String
  commonArea    CommonArea        @relation(fields: [commonAreaId], references: [id], onDelete: Restrict)
  residentId    String
  resident      Resident          @relation(fields: [residentId], references: [id], onDelete: Cascade)
  startsAt      DateTime
  endsAt        DateTime
  status        ReservationStatus @default(PENDING)
  notes         String?
  responseMessage String?         // resposta do síndico ao aprovar/rejeitar/cancelar
  respondedAt     DateTime?
  canceledAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Evita duas reservas idênticas no mesmo slot; conflito de range tratado em lógica + constraint de exclusão (SQL).
  @@index([commonAreaId, startsAt, endsAt])
  @@index([condominiumId, status])
  @@index([residentId])
}

// ============================================================
// FINANCEIRO (do condomínio)
// ============================================================

model ExpenseCategory {
  id            String    @id @default(uuid())
  condominiumId String
  name          String
  expenses      Expense[]

  @@unique([condominiumId, name])
}

model Expense {
  id            String           @id @default(uuid())
  condominiumId String
  condominium   Condominium      @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description   String
  amount        Decimal          @db.Decimal(12, 2)
  dueDate       DateTime
  paidAt        DateTime?
  receiptUrl    String?
  createdAt     DateTime         @default(now())

  @@index([condominiumId, dueDate])
}

model Revenue {
  id            String      @id @default(uuid())
  condominiumId String
  condominium   Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  description   String
  amount        Decimal     @db.Decimal(12, 2)
  receivedAt    DateTime
  category      String?
  createdAt     DateTime    @default(now())

  @@index([condominiumId, receivedAt])
}

// ============================================================
// COBRANÇA DO MORADOR (taxa condominial via PIX/Boleto)
// Não confundir com Payment (cobrança B2B da plataforma ao condomínio).
// ============================================================

enum ChargeKind {
  CONDO_FEE   // taxa condominial mensal
  RESERVATION // cobrança de reserva de área comum (reuso futuro)
  EXTRA       // cobrança avulsa (multa, rateio)
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum ChargeMethod {
  PIX
  BOLETO
}

model Charge {
  id             String       @id @default(uuid())
  condominiumId  String
  condominium    Condominium  @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  apartmentId    String
  apartment      Apartment    @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  residentId     String?      // pagador (opcional; a cobrança é da unidade)
  resident       Resident?    @relation(fields: [residentId], references: [id], onDelete: SetNull)
  batchId        String?
  batch          ChargeBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  kind           ChargeKind   @default(CONDO_FEE)
  description    String
  referenceMonth String?      // "2026-06" para taxas mensais
  amount         Decimal      @db.Decimal(12, 2)
  fineAmount     Decimal?     @db.Decimal(12, 2) // multa por atraso
  interestAmount Decimal?     @db.Decimal(12, 2) // juros
  paidAmount     Decimal?     @db.Decimal(12, 2)
  dueDate        DateTime
  status         ChargeStatus @default(PENDING)
  method         ChargeMethod @default(PIX)

  // Dados do gateway (nunca armazenar dados de cartão).
  gatewayChargeId String?     @unique
  pixPayload      String?     @db.Text // copia-e-cola
  pixQrCodeUrl    String?
  boletoUrl       String?
  paidAt          DateTime?
  canceledAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([condominiumId, status, dueDate])
  @@index([apartmentId])
  @@index([referenceMonth])
}

// Lote mensal de geração de cobranças (uma corrida = um mês).
model ChargeBatch {
  id             String      @id @default(uuid())
  condominiumId  String
  condominium    Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  referenceMonth String      // "2026-06"
  dueDate        DateTime
  defaultAmount  Decimal     @db.Decimal(12, 2)
  totalCharges   Int         @default(0)
  createdAt      DateTime    @default(now())

  charges        Charge[]

  @@unique([condominiumId, referenceMonth])
  @@index([condominiumId])
}

// Idempotência de webhook do gateway (cross-tenant; sem condominiumId).
model WebhookEvent {
  id          String   @id @default(uuid())
  provider    String   // "asaas"
  eventId     String   // id do evento no gateway
  type        String
  payload     Json
  processedAt DateTime @default(now())

  @@unique([provider, eventId])
}

// ============================================================
// ASSEMBLEIAS / VOTAÇÃO ONLINE (Lei 14.309/2022)
// ============================================================

enum AssemblyType {
  ORDINARIA    // AGO
  EXTRAORDINARIA // AGE
}

enum AssemblyMode {
  PRESENCIAL
  VIRTUAL
  HIBRIDA
}

enum AssemblyStatus {
  DRAFT       // rascunho do edital
  SCHEDULED   // convocada/publicada
  OPEN        // em andamento
  CLOSED      // encerrada
  CANCELED
}

enum AssemblyItemStatus {
  PENDING
  OPEN        // votação aberta
  CLOSED      // apurada
}

// Regra de aprovação do item (quórum deliberativo).
enum QuorumRule {
  SIMPLE_MAJORITY   // maioria dos votos presentes (exclui abstenções)
  ABSOLUTE_MAJORITY // > 50% da fração ideal total do condomínio
  TWO_THIRDS        // >= 2/3 da fração ideal total
  UNANIMITY         // 100% da fração ideal total
}

enum VoteChoice {
  YES
  NO
  ABSTAIN
  OPTION // voto em opção específica (item de múltipla escolha)
}

model Assembly {
  id            String         @id @default(uuid())
  condominiumId String
  condominium   Condominium    @relation(fields: [condominiumId], references: [id], onDelete: Cascade)

  title         String
  // Edital/convocação (texto rico em markdown/plain).
  notice        String         @db.Text
  type          AssemblyType   @default(ORDINARIA)
  mode          AssemblyMode   @default(VIRTUAL)
  status        AssemblyStatus @default(DRAFT)

  scheduledFor  DateTime       // data/hora oficial da assembleia
  // Quórum de instalação (fração ideal mínima presente). 1ª e 2ª convocação.
  quorumFirst   Decimal        @default(0.5) @db.Decimal(4, 3)
  quorumSecond  Decimal?       @db.Decimal(4, 3) // null = qualquer número (2ª chamada)
  meetingUrl    String?        // link da videochamada (modo virtual/híbrido)

  openedAt      DateTime?
  closedAt      DateTime?
  minutesUrl    String?        // ata gerada (PDF no storage)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  items         AssemblyItem[]
  attendances   AssemblyAttendance[]

  @@index([condominiumId, status, scheduledFor])
}

model AssemblyItem {
  id          String             @id @default(uuid())
  assemblyId  String
  assembly    Assembly           @relation(fields: [assemblyId], references: [id], onDelete: Cascade)

  order       Int                @default(0)
  title       String
  description String?            @db.Text
  quorumRule  QuorumRule         @default(SIMPLE_MAJORITY)
  status      AssemblyItemStatus @default(PENDING)

  openedAt    DateTime?
  closedAt    DateTime?
  // Resultado apurado no fechamento (snapshot).
  approved    Boolean?
  resultJson  Json?

  options     AssemblyOption[]
  votes       AssemblyVote[]

  @@index([assemblyId, order])
}

// Opções de itens de múltipla escolha (ex.: eleição de síndico).
model AssemblyOption {
  id      String         @id @default(uuid())
  itemId  String
  item    AssemblyItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  label   String
  order   Int            @default(0)
  votes   AssemblyVote[]

  @@index([itemId])
}

model AssemblyVote {
  id          String       @id @default(uuid())
  itemId      String
  item        AssemblyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  apartmentId String       // voto é por unidade
  apartment   Apartment    @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  residentId  String?      // quem registrou o voto
  resident    Resident?    @relation(fields: [residentId], references: [id], onDelete: SetNull)
  optionId    String?
  option      AssemblyOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  choice      VoteChoice
  weight      Decimal      @db.Decimal(9, 6) // fração ideal no momento do voto
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([itemId, apartmentId]) // uma unidade, um voto por item
  @@index([itemId])
}

// Presença/check-in — base do cálculo de quórum de instalação.
model AssemblyAttendance {
  id          String     @id @default(uuid())
  assemblyId  String
  assembly    Assembly   @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  apartmentId String
  apartment   Apartment  @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  residentId  String?
  resident    Resident?  @relation(fields: [residentId], references: [id], onDelete: SetNull)
  weight      Decimal    @db.Decimal(9, 6)
  checkedInAt DateTime   @default(now())

  @@unique([assemblyId, apartmentId])
  @@index([assemblyId])
}

// ============================================================
// CHAMADOS / MANUTENÇÃO
// ============================================================

enum TicketCategory {
  LEAK         // vazamento
  CLEANING     // limpeza
  NOISE        // barulho
  SECURITY     // segurança
  MAINTENANCE  // manutenção
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id            String         @id @default(uuid())
  condominiumId String
  condominium   Condominium    @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  residentId    String
  resident      Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  assigneeId    String?
  assignee      User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  category      TicketCategory @default(OTHER)
  priority      TicketPriority @default(MEDIUM)
  status        TicketStatus   @default(OPEN)
  title         String
  description   String         @db.Text
  resolvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  comments      TicketComment[]
  attachments   TicketAttachment[]

  @@index([condominiumId, status, priority])
  @@index([residentId])
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model TicketAttachment {
  id        String @id @default(uuid())
  ticketId  String
  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileUrl   String
  fileName  String
  mimeType  String

  @@index([ticketId])
}

// ============================================================
// PORTARIA: VISITANTES & ENCOMENDAS
// ============================================================

enum VisitorStatus {
  EXPECTED     // pré-cadastrado pelo morador
  CHECKED_IN
  CHECKED_OUT
  DENIED
}

model Visitor {
  id            String        @id @default(uuid())
  condominiumId String
  condominium   Condominium   @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  residentId    String        // morador que recebe / autorizou
  resident      Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  fullName      String
  document      String?       // RG/CPF
  photoUrl      String?
  qrCode        String        @unique // token do QR de acesso
  status        VisitorStatus @default(EXPECTED)
  expectedAt    DateTime?
  expiresAt     DateTime?     // validade do QR (após isso, não pode mais dar entrada)
  checkedInAt   DateTime?
  checkedOutAt  DateTime?
  registeredBy  String?       // userId do porteiro no check-in
  createdAt     DateTime      @default(now())

  @@index([condominiumId, status])
  @@index([residentId])
  @@index([qrCode])
}

enum PackageStatus {
  RECEIVED     // recebida na portaria
  NOTIFIED
  PICKED_UP    // retirada
}

model Package {
  id            String        @id @default(uuid())
  condominiumId String
  condominium   Condominium   @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  apartmentId   String
  apartment     Apartment     @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  residentId    String?
  resident      Resident?     @relation(fields: [residentId], references: [id], onDelete: SetNull)
  description   String?
  carrier       String?       // transportadora
  photoUrl      String?
  status        PackageStatus @default(RECEIVED)
  receivedBy    String?       // userId porteiro
  receivedAt    DateTime      @default(now())
  pickedUpAt    DateTime?
  pickedUpBy    String?       // nome de quem retirou

  @@index([condominiumId, status])
  @@index([apartmentId])
}

// ============================================================
// NOTIFICAÇÕES & AUDITORIA
// ============================================================

enum NotificationType {
  NOTICE
  RESERVATION
  TICKET
  PACKAGE
  VISITOR
  BILLING
  SYSTEM
}

model Notification {
  id            String           @id @default(uuid())
  condominiumId String
  condominium   Condominium      @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  userId        String           // destinatário
  type          NotificationType
  title         String
  body          String
  linkUrl       String?          // deep link no app
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())

  @@index([userId, isRead])
  @@index([condominiumId])
}

// Trilha de auditoria — quem fez o quê em recursos sensíveis.
model AuditLog {
  id            String      @id @default(uuid())
  condominiumId String?
  condominium   Condominium? @relation(fields: [condominiumId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String      // "resident.approve", "expense.delete", "auth.login"
  entity        String      // "Resident", "Expense"
  entityId      String?
  metadata      Json?
  ipAddress     String?
  createdAt     DateTime    @default(now())

  @@index([condominiumId, createdAt])
  @@index([userId])
  @@index([entity, entityId])
}

// ============================================================
// CONVITES (onboarding de morador/porteiro)
// ============================================================

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// Convite por token: síndico convida → convidado define senha e cria o login.
model Invitation {
  id            String           @id @default(uuid())
  condominiumId String
  condominium   Condominium      @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  email         String
  name          String
  role          UserRole // MORADOR ou PORTEIRO (validado na aplicação)
  // Vínculo opcional com um cadastro de morador (link login → unidade).
  residentId    String?          @unique
  resident      Resident?        @relation(fields: [residentId], references: [id], onDelete: SetNull)
  token         String           @unique
  status        InvitationStatus @default(PENDING)
  invitedById   String?
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime         @default(now())

  @@index([condominiumId, status])
  @@index([token])
  }

// ============================================================
// SUGESTÕES DE MELHORIA (mural de ideias com votação)
// ============================================================

enum SuggestionCategory {
  COMMON_AREAS    // áreas comuns / lazer
  SECURITY        // segurança
  SUSTAINABILITY  // sustentabilidade
  INFRASTRUCTURE  // infraestrutura / obras
  FINANCE         // financeiro
  OTHER
}

enum SuggestionStatus {
  OPEN          // aberta para votação
  UNDER_REVIEW  // em análise pela administração
  PLANNED       // aprovada / planejada
  DONE          // concluída
  REJECTED      // recusada
}

model Suggestion {
  id              String             @id @default(uuid())
  condominiumId   String
  condominium     Condominium        @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  residentId      String             // autor
  resident        Resident           @relation(fields: [residentId], references: [id], onDelete: Cascade)

  title           String
  description     String             @db.Text
  category        SuggestionCategory @default(OTHER)
  status          SuggestionStatus   @default(OPEN)

  // Resposta oficial da administração ao mudar o status.
  responseMessage String?
  respondedAt     DateTime?

  votes           SuggestionVote[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([condominiumId, status])
}

// Apoio do morador a uma sugestão (1 voto por morador).
model SuggestionVote {
  id           String     @id @default(uuid())
  suggestionId String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  residentId   String
  resident     Resident   @relation(fields: [residentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([suggestionId, residentId])
  @@index([suggestionId])
}

// ============================================================
// LGPD — consentimento versionado (base legal e prova de aceite)
// ============================================================

enum ConsentDocument {
  TERMS_OF_USE
  PRIVACY_POLICY
}

model ConsentRecord {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   ConsentDocument
  version    String          // versão do documento aceita (ex.: "2026-06-17")
  acceptedAt DateTime        @default(now())
  ipAddress  String?
  userAgent  String?

  @@index([userId])
}
